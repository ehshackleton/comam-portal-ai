NODE_ENV=production
APP_NAME="COMAM Portal AI"
APP_DOMAIN=comam.granlogiamixta.cl
APP_URL=https://comam.granlogiamixta.cl
NEXT_PUBLIC_APP_URL=https://comam.granlogiamixta.cl

TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt

AUTH_SECRET=change_me
NEXTAUTH_SECRET=change_me
PAYLOAD_SECRET=change_me
ENCRYPTION_KEY=change_me

POSTGRES_DB=comam
POSTGRES_USER=comam
POSTGRES_PASSWORD=change_me
# Docker Compose (contenedor comam-web):
DATABASE_URL=postgresql://comam:change_me@postgres:5432/comam
# Desarrollo local con pnpm dev (host → localhost, ver scripts/dev-local.sh):
# DATABASE_URL=postgresql://comam:change_me@localhost:5432/comam

REDIS_PASSWORD=change_me
REDIS_URL=redis://:change_me@redis:6379

OTP_ISSUER=COMAM
OTP_REQUIRED_FOR_ADMIN=true
OTP_RECOVERY_CODES_ENABLED=true

ADMIN_EMAIL=admin@comam.cl
ADMIN_INITIAL_PASSWORD=change_me
ADMIN_REQUIRE_OTP_SETUP=true

OPENAI_API_KEY=change_me
AI_DEFAULT_MODEL=gpt-4.1-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_PUBLIC_AGENT_ENABLED=true
AI_INTERNAL_AGENT_ENABLED=true

S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=https://comam.granlogiamixta.cl/api/files
S3_REGION=us-east-1
S3_BUCKET=comam-documents
S3_ACCESS_KEY_ID=comamadmin
S3_SECRET_ACCESS_KEY=change_me
S3_FORCE_PATH_STYLE=true

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change_me
SMTP_PASSWORD=change_me
EMAIL_FROM="COMAM 2026 <no-reply@comam.cl>"
EMAIL_REPLY_TO=contacto@comam.cl

CONFERENCE_YEAR=2026
CONFERENCE_CITY="Santiago de Chile"
CONFERENCE_NAME="Conferencia COMAM 2026"
REGISTRATION_ENABLED=true

SESSION_MAX_AGE_SECONDS=28800
ADMIN_SESSION_MAX_AGE_SECONDS=7200
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
AUDIT_LOG_ENABLED=true

CRON_SECRET=change_me
