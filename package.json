{
  "name": "comam-portal-ai",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev-local.sh",
    "build": "pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "db:generate": "pnpm --filter @comam/db generate",
    "db:migrate": "pnpm --filter @comam/db migrate",
    "db:seed": "pnpm --filter @comam/db seed",
    "db:reset-admin": "pnpm --filter @comam/db reset-admin",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0"
}
